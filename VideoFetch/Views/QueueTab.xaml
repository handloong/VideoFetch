<UserControl x:Class="VideoFetch.Views.QueueTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:VideoFetch.Models"
             xmlns:conv="clr-namespace:VideoFetch.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvertBoolToVis" Invert="True"/>
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="{DynamicResource Btn_ClearCompleted}"
                    Command="{Binding ClearCompletedCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Padding="8,3"/>
            <Button Content="{DynamicResource Btn_OpenFolder}"
                    Command="{Binding OpenOutputFolderCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="8,0,0,0" Padding="8,3"/>
        </StackPanel>

        <!-- Download list -->
        <ListView Grid.Row="1" ItemsSource="{Binding DownloadItems}"
                  Background="Transparent" BorderThickness="0"
                  ItemContainerStyle="{StaticResource FlatListViewItemStyle}"
                  MouseDoubleClick="QueueList_MouseDoubleClick">
            <ListView.View>
                <GridView AllowsColumnReorder="False">
                    <GridViewColumn Header="{DynamicResource Queue_Header_Title}" Width="220">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:DownloadItem}">
                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Title}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Padding="6,4" FontSize="12"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="{DynamicResource Queue_Header_Progress}" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:DownloadItem}">
                                <ProgressBar Value="{Binding Progress}" Maximum="100"
                                             Height="6" Width="80"
                                             HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="{DynamicResource Queue_Header_Status}" Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:DownloadItem}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Status}" FontSize="11"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                               Padding="6,2"/>
                                    <TextBlock Text="{Binding Speed}" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}" Padding="6,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="{DynamicResource Queue_Header_Actions}" Width="140">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:DownloadItem}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Content="{DynamicResource Btn_CancelDownload}"
                                            Command="{Binding DataContext.CancelDownloadCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            FontSize="10" Padding="5,2"
                                            Visibility="{Binding IsCompleted, Converter={StaticResource InvertBoolToVis}}"/>
                                    <Button Content="{DynamicResource Btn_DeleteLocalFile}"
                                            Command="{Binding DataContext.DeleteLocalFileCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            FontSize="10" Padding="5,2"
                                            Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
