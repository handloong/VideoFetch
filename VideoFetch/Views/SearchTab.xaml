<UserControl x:Class="VideoFetch.Views.SearchTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:VideoFetch.Models"
             xmlns:conv="clr-namespace:VideoFetch.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvertBoolToVis" Invert="True"/>
        <conv:NotNullOrEmptyConverter x:Key="NotNullOrEmpty"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding SupportedSites}"
                          SelectedItem="{Binding SearchSite}"
                          Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                <Button Grid.Column="2" Content="{DynamicResource Btn_Search}"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="8,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Status Message -->
        <TextBlock Grid.Row="1" Text="{Binding SearchStatusMessage}"
                   FontSize="11" Foreground="{StaticResource AccentBrush}"
                   Margin="0,0,0,4"
                   Visibility="{Binding SearchStatusMessage, Converter={StaticResource NotNullOrEmpty}}"/>

        <!-- Results Container -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Batch action toolbar -->
            <Border Grid.Row="0" Background="{StaticResource BgTertiaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="8,5"
                    Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <Button Content="{DynamicResource Btn_SelectAll}"
                            Command="{Binding SelectAllResultsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="10" Padding="8,2" Margin="0,0,5,0"/>
                    <Button Content="{DynamicResource Btn_InvertSelection}"
                            Command="{Binding InvertSelectionCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="10" Padding="8,2" Margin="0,0,8,0"/>
                    <Separator Style="{StaticResource VerticalSepStyle}"/>
                    <CheckBox Content="{DynamicResource Btn_IncludeDownloaded}"
                              IsChecked="{Binding IncludeAlreadyDownloaded}"
                              FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center"
                              ToolTip="{DynamicResource Tip_IncludeDownloaded}"/>
                    <Separator Style="{StaticResource VerticalSepStyle}"/>
                    <Button Command="{Binding BatchDownloadCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            FontSize="10" Padding="10,2" Margin="8,0,6,0"
                            Content="{Binding BatchDownloadText}"/>
                    <TextBlock Text="{DynamicResource Hint_DoubleClick}" FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="6,0,0,0"
                               Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>

            <!-- Results ListView -->
            <ListView Grid.Row="1" ItemsSource="{Binding SearchResults}"
                      SelectionMode="Extended" Background="Transparent" BorderThickness="0"
                      ItemContainerStyle="{StaticResource FlatListViewItemStyle}"
                      ScrollViewer.CanContentScroll="False"
                      Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVis}}"
                      MouseDoubleClick="SearchResultsList_MouseDoubleClick">
                <ListView.View>
                    <GridView AllowsColumnReorder="False">
                        <GridViewColumn Header="#" Width="40">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:SearchResult}">
                                    <TextBlock Text="{Binding Index}" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="" Width="36">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:SearchResult}">
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{DynamicResource Col_Title}" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:SearchResult}">
                                    <Grid>
                                        <TextBlock Text="{Binding Title}" FontSize="12"
                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Title}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" Padding="6,4"/>
                                        <Border BorderThickness="3,0,0,0" BorderBrush="#4CAF50" Opacity="0.6"
                                                Visibility="{Binding IsAlreadyDownloaded, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{DynamicResource Col_Source}" Width="65">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:SearchResult}">
                                    <Border CornerRadius="3" Background="{StaticResource AccentBrush}"
                                            Opacity="0.7" Padding="3,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Site}" FontSize="9" FontWeight="Medium" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:SearchResult}">
                                    <Grid>
                                        <Button Content="{DynamicResource Btn_DownloadRow}"
                                                Command="{Binding DataContext.DownloadSearchResultCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                FontSize="9" Padding="6,2"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Visibility="{Binding IsAlreadyDownloaded, Converter={StaticResource InvertBoolToVis}}"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding IsAlreadyDownloaded, Converter={StaticResource BoolToVis}}">
                                            <Border CornerRadius="3" Background="#2E7D32" Padding="4,1">
                                                <TextBlock Text="✓ 已下载" FontSize="9" Foreground="White" FontWeight="Medium"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Empty state -->
            <Border Grid.Row="1" Grid.RowSpan="2" Background="Transparent"
                    Visibility="{Binding HasSearchResults, Converter={StaticResource InvertBoolToVis}, FallbackValue=Visible}">
                <TextBlock Text="{DynamicResource Empty_SearchResults}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" HorizontalAlignment="Center"
                           VerticalAlignment="Center" TextAlignment="Center"/>
            </Border>

            <!-- Load more -->
            <Button Grid.Row="2" Content="{DynamicResource Btn_LoadMore}"
                    Command="{Binding LoadMoreSearchResultsCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="0,6,0,0" Padding="14,5"
                    Visibility="{Binding HasMoreResults, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Grid>
</UserControl>
