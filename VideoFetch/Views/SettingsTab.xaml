<UserControl x:Class="VideoFetch.Views.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VideoFetch.Converters">
    <UserControl.Resources>
        <conv:NotNullOrEmptyConverter x:Key="NotNullOrEmpty"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar: title + save button -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="12,10">
            <Grid>
                <TextBlock Text="{DynamicResource Settings_General}" FontSize="14" FontWeight="Medium"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SettingsSavedMessage}"
                               Foreground="{StaticResource SuccessBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,10,0"
                               Visibility="{Binding SettingsSavedMessage, Converter={StaticResource NotNullOrEmpty}}"/>
                    <Button Content="{DynamicResource Btn_SaveSettings}"
                            Command="{Binding SaveSettingsCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="16,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Settings content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- General settings -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <Label Content="{DynamicResource Settings_OutputDir}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Settings.OutputDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="{DynamicResource Btn_BrowseFolder}"
                                    Command="{Binding BrowseOutputFolderCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0"/>
                        </Grid>
                        <Separator Margin="0,8"/>
                        <Label Content="{DynamicResource Settings_MaxConcurrent}"/>
                        <TextBox Text="{Binding Settings.MaxConcurrentDownloads, UpdateSourceTrigger=PropertyChanged}"
                                 Width="80" HorizontalAlignment="Left"/>
                        <Separator Margin="0,8"/>
                        <CheckBox Content="{DynamicResource Settings_AutoOpenFolder}"
                                  IsChecked="{Binding Settings.AutoOpenFolder}" Margin="0,4"/>
                        <CheckBox Content="{DynamicResource Settings_CreateSubfolders}"
                                  IsChecked="{Binding Settings.CreateSubfolders}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Network settings -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <Label Content="{DynamicResource Settings_Network}" FontWeight="Medium"/>
                        <Label Content="{DynamicResource Settings_ProxyAddress}"/>
                        <TextBox Text="{Binding Settings.ProxyUrl, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Player settings -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <Label Content="{DynamicResource Settings_Player}" FontWeight="Medium"/>
                        <CheckBox Content="{DynamicResource Settings_UseBuiltInPlayer}"
                                  IsChecked="{Binding Settings.UseBuiltInPlayer}" Margin="0,4"/>
                        <TextBlock Text="{DynamicResource Settings_BuiltInPlayerHint}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="24,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Language (hidden) -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Language_Label}" FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                        <ComboBox x:Name="LangCombo" SelectionChanged="LangCombo_SelectionChanged"
                                  Width="140" FontSize="12" Padding="6,4" HorizontalAlignment="Left">
                            <ComboBoxItem Tag="zh-CN" Content="{DynamicResource Lang_ZhCN}"/>
                            <ComboBoxItem Tag="en-US" Content="{DynamicResource Lang_ENUS}"/>
                        </ComboBox>
                        <TextBlock Text="切换语言后将自动重启应用" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
