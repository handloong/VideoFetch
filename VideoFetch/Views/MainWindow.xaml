<Window x:Class="VideoFetch.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VideoFetch.ViewModels"
        xmlns:views="clr-namespace:VideoFetch.Views"
        xmlns:conv="clr-namespace:VideoFetch.Converters"
        Title="{DynamicResource AppTitle}"
        Width="1000" Height="700"
        MinWidth="880" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource BaseWindowStyle}"
        x:Name="mainWindow">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- ══ ROOT LAYOUT ══════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>   <!-- Title bar -->
            <RowDefinition Height="Auto"/> <!-- Header toolbar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ════════════ TITLE BAR ════════════ -->
        <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}">
            <Grid Margin="16,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Border Width="22" Height="22" CornerRadius="5" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="VF" Foreground="White" FontWeight="Bold"
                                   FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{DynamicResource HeaderTitle}" FontSize="12" FontWeight="Medium"
                               VerticalAlignment="Center" Margin="8,0,0,0"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding AppVersion, StringFormat=v{0}}" FontSize="10" Margin="6,0,0,0"
                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <Grid Grid.Column="1" Background="Transparent"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Stretch" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource MinimizeBtnStyle}" Click="BtnMinimize_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource CloseBtnStyle}" Click="BtnClose_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════ HEADER TOOLBAR ════════════ -->
        <Border Grid.Row="1" Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center" x:Name="UrlBox">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding FetchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Content="{DynamicResource Btn_PasteUrl}"
                            Command="{Binding PasteUrlCommand}" Style="{StaticResource SecondaryButtonStyle}"
                            Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="{DynamicResource Btn_FetchInfo}"
                            Command="{Binding FetchCommand}" Style="{StaticResource PrimaryButtonStyle}"
                            Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsFetching, Converter={StaticResource BoolToVis}}" Margin="16,0,0,0">
                    <TextBlock Text="{DynamicResource Status_Fetching}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════ MAIN CONTENT ════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Download panel -->
            <views:DownloadTab Grid.Column="0"/>

            <!-- Resizer -->
            <GridSplitter Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}"
                          VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

            <!-- Right: Tabs -->
            <TabControl Grid.Column="2" Background="Transparent" BorderThickness="0" SelectedIndex="{Binding SelectedTab}">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="14,9"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Border" Padding="{TemplateBinding Padding}"
                                            BorderBrush="Transparent" BorderThickness="0,0,0,2">
                                        <ContentPresenter ContentSource="Header"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="{DynamicResource Tab_Search}">
                    <views:SearchTab/>
                </TabItem>
                <TabItem Header="{DynamicResource Tab_Queue}">
                    <views:QueueTab/>
                </TabItem>
                <TabItem Header="{DynamicResource Tab_Settings}">
                    <views:SettingsTab/>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- ════════════ STATUS BAR ════════════ -->
        <Border Grid.Row="3" Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding FetchStatusMessage}" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                    <Run Text="{DynamicResource Status_Downloads}"/>
                    <Run Text="{Binding DownloadItems.Count, Mode=OneWay}"/>
                    <Run Text="  |  "/>
                    <Run Text="{DynamicResource Status_Results}"/>
                    <Run Text="{Binding SearchResults.Count, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
