<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════
         中文语言包 (zh-CN) - 默认语言
         ═══════════════════════════════════════════════════ -->

    <!-- ── 窗口标题 / Header ──────────────────────── -->
    <sys:String x:Key="AppTitle">VideoFetch - 视频下载工具</sys:String>
    <sys:String x:Key="HeaderTitle">VideoFetch</sys:String>

    <!-- Tab names -->
    <sys:String x:Key="Tab_Download">📥 下载</sys:String>
    <sys:String x:Key="Tab_Search">🔍 搜索</sys:String>
    <sys:String x:Key="Tab_Queue">⏳ 下载</sys:String>
    <sys:String x:Key="Tab_Settings">⚙ 设置</sys:String>

    <!-- ── Download tab ─────────────────────────────── -->
    <sys:String x:Key="UrlPlaceholder">粘贴视频链接 (PornHub / XVideos / XNXX)... 按 Ctrl+V 快速粘贴</sys:String>
    <sys:String x:Key="Btn_PasteUrl">📋 粘贴并获取</sys:String>
    <sys:String x:Key="Btn_FetchInfo">🔍 获取视频信息</sys:String>
    <sys:String x:Key="Label_VideoTitle">视频标题</sys:String>
    <sys:String x:Key="Label_Author">作者</sys:String>
    <sys:String x:Key="Label_Duration">时长</sys:String>
    <sys:String x:Key="Label_QualitySelect">选择画质</sys:String>
    <sys:String x:Key="Btn_Download">⬇ 开始下载</sys:String>
    <sys:String x:Key="Status_Fetching">正在获取视频信息...</sys:String>
    <sys:String x:Key="Status_AddedToQueue">已加入队列：</sys:String>
    <sys:String x:Key="Error_UnsupportedURL">不支持的链接。支持：PornHub、xvideos、xnxx</sys:String>
    <sys:String x:Key="Label_OutputFolder">保存目录：</sys:String>
    <sys:String x:Key="Btn_BrowseFolder">浏览...</sys:String>
    <sys:String x:Key="Btn_OpenFolder">打开文件夹</sys:String>

    <!-- ── Search tab ───────────────────────────────── -->
    <sys:String x:Key="Search_Placeholder">输入关键词搜索...</sys:String>
    <sys:String x:Key="Btn_Search">🔍 搜索</sys:String>
    <sys:String x:Key="Label_SiteSelect">搜索站点：</sys:String>

    <!-- Search results table headers -->
    <sys:String x:Key="Col_Index">序号</sys:String>
    <sys:String x:Key="Col_Checkbox">☐</sys:String>
    <sys:String x:Key="Col_Title">标题</sys:String>
    <sys:String x:Key="Col_Source">来源</sys:String>
    <sys:String x:Key="Col_Download">操作</sys:String>

    <!-- Batch actions -->
    <sys:String x:Key="Btn_SelectAll">☑ 全选</sys:String>
    <sys:String x:Key="Btn_InvertSelection">☐ 反选</sys:String>
    <sys:String x:Key="Btn_BatchDownload">⬇ 批量下载选中项 ({0})</sys:String>
    <sys:String x:Key="Hint_DoubleClick">双击行可预览缩略图（ESC关闭）</sys:String>
    <sys:String x:Key="Btn_DownloadRow">⬇ 下载</sys:String>
    <sys:String x:Key="Btn_LoadMore">加载更多结果...</sys:String>
    <sys:String x:Key="Btn_IncludeDownloaded">包含已下载项</sys:String>
    <sys:String x:Key="Tip_IncludeDownloaded">勾选后，已下载过的视频也会被重新下载（类似迅雷强制重下载）</sys:String>

    <!-- Empty state -->
    <sys:String x:Key="Empty_SearchResults">在上方输入关键词并点击"搜索"，或加载下方分类。</sys:String>

    <!-- Search status messages -->
    <sys:String x:Key="Status_Searching">正在 {0} 搜索「{1}」...</sys:String>
    <sys:String x:Key="Status_FoundResults">找到 {0} 条结果</sys:String>
    <sys:String x:Key="Status_NoResults">未找到结果，试试其他关键词。</sys:String>
    <sys:String x:Key="Status_SearchError">搜索错误：{0}</sys:String>
    <sys:String x:Key="Status_LoadingPage">正在加载第 {0} 页...</sys:String>
    <sys:String x:Key="Status_TotalResults">共加载 {0} 条结果</sys:String>
    <sys:String x:Key="Status_LoadingMoreError">加载更多出错：{0}</sys:String>
    <sys:String x:Key="Status_PreparingDownload">正在准备下载：{0}</sys:String>

    <!-- Queue tab -->
    <sys:String x:Key="Queue_Empty">暂无下载任务</sys:String>
    <sys:String x:Key="Queue_Header_Title">标题</sys:String>
    <sys:String x:Key="Queue_Header_Progress">进度</sys:String>
    <sys:String x:Key="Queue_Header_Status">状态</sys:String>
    <sys:String x:Key="Queue_Header_Speed">速度</sys:String>
    <sys:String x:Key="Queue_Header_Actions">操作</sys:String>
    <sys:String x:Key="Btn_CancelDownload">取消</sys:String>
    <sys:String x:Key="Btn_ClearCompleted">清除已完成</sys:String>
    <sys:String x:Key="Btn_DeleteLocalFile">🗑 删除本地文件</sys:String>

    <!-- Settings tab -->
    <sys:String x:Key="Settings_General">通用设置</sys:String>
    <sys:String x:Key="Settings_OutputDir">默认保存目录</sys:String>
    <sys:String x:Key="Settings_MaxConcurrent">最大同时下载数</sys:String>
    <sys:String x:Key="Settings_DefaultQuality">默认画质</sys:String>
    <sys:String x:Key="Quality_Option_Best">最佳画质</sys:String>
    <sys:String x:Key="Settings_AutoOpenFolder">下载完成后自动打开文件夹</sys:String>
    <sys:String x:Key="Settings_CreateSubfolders">按网站自动创建子文件夹</sys:String>
    <sys:String x:Key="Settings_Network">网络设置</sys:String>
    <sys:String x:Key="Settings_ProxyAddress">代理地址（留空则不使用代理）</sys:String>
    <sys:String x:Key="Settings_Player">播放设置</sys:String>
    <sys:String x:Key="Settings_UseBuiltInPlayer">使用内置播放器</sys:String>
    <sys:String x:Key="Settings_BuiltInPlayerHint">关闭则调用系统默认播放器（如 PotPlayer / MPC）</sys:String>
    <sys:String x:Key="Btn_SaveSettings">💾 保存设置</sys:String>

    <!-- Language switcher -->
    <sys:String x:Key="Language_Label">语言：</sys:String>
    <sys:String x:Key="Lang_ZhCN">中文</sys:String>
    <sys:String x:Key="Lang_ENUS">English</sys:String>

    <!-- Quick tips -->
    <sys:String x:Key="Label_SupportedSites">支持网站</sys:String>
    <sys:String x:Key="Label_QuickTips">快速提示：</sys:String>
    <sys:String x:Key="Tip_PasteUrl">- 粘贴链接后点击"获取视频信息"</sys:String>
    <sys:String x:Key="Tip_SearchTab">- 使用搜索标签页发现视频</sys:String>
    <sys:String x:Key="Tip_ClickResult">- 点击搜索结果可加载详情</sys:String>

    <!-- Status bar -->
    <sys:String x:Key="Status_Downloads">下载中：</sys:String>
    <sys:String x:Key="Status_Results">结果：</sys:String>

    <!-- Generic -->
    <sys:String x:Key="Error_Generic">错误：{0}</sys:String>

</ResourceDictionary>
